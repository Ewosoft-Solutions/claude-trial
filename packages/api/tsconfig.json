{
  "extends": "@workspace/typescript-config/nestjs.json",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@workspace/database": ["../database/src/client.ts"],
      "@workspace/database/*": ["../database/src/*"]
    },
    "esModuleInterop": true,
    "incremental": false,
    "outDir": "dist",
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "test", "dist", "**/*spec.ts"]
}
