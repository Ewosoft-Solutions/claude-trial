// ============================================
// Academic Structure Models
// ============================================
//
// Schema Design Notes:
//
// 1. AcademicYear:
//    - Tenant-scoped academic years (e.g., "2024-2025")
//    - Start and end dates
//    - Status tracking (active, planned, completed)
//    - Default/current year flag
//
// 2. Term:
//    - Belongs to an AcademicYear
//    - Types: semester, trimester, quarter, etc.
//    - Start and end dates
//    - Order/sequence for display
//    - Status tracking (active, planned, completed)
//
// 3. Course:
//    - Tenant-scoped course catalog
//    - Course code (e.g., "MATH101")
//    - Name, description, category
//    - Grade levels (which grades can take this course)
//    - Credits/hours
//    - Status (active, archived)
//
// 4. Class:
//    - Course offering in a specific term
//    - Section identifier (e.g., "A", "B", "Section 1")
//    - Capacity (max students)
//    - Schedule information (JSONB for flexibility)
//    - Status (active, full, cancelled)
//    - Teacher assignments (many-to-many via ClassTeacher)
//
// See: _requirements/academic-structure.md for complete academic structure design
// ============================================

// AcademicYear - School academic years (e.g., "2024-2025")
model AcademicYear {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String // e.g., "2024-2025", "Academic Year 2024"
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  status      String   @default("planned") // 'active' | 'planned' | 'completed' | 'archived'
  isDefault   Boolean  @default(false) @map("is_default") // Current/default year for the school
  description String?

  // Audit Fields
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  terms       Term[]
  classes     Class[]
  enrollments Enrollment[]
  assessments Assessment[]

  @@unique([tenantId, name]) // Unique name per tenant
  @@index([tenantId])
  @@index([status])
  @@index([isDefault])
  @@index([startDate, endDate])
  @@map("academic_years")
}

// Term - Academic terms within an academic year (semester, trimester, quarter, etc.)
model Term {
  id             String   @id @default(uuid())
  academicYearId String   @map("academic_year_id")
  name           String // e.g., "Fall Term", "Semester 1", "Trimester 1"
  type           String // 'semester' | 'trimester' | 'quarter' | 'term' | 'custom'
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  order          Int // Sequence/order for display (1, 2, 3, etc.)
  status         String   @default("planned") // 'active' | 'planned' | 'completed' | 'archived'
  description    String?

  // Audit Fields
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classes      Class[]
  enrollments  Enrollment[]
  assessments  Assessment[]

  @@unique([academicYearId, name]) // Unique name per academic year
  @@index([academicYearId])
  @@index([status])
  @@index([order])
  @@index([startDate, endDate])
  @@map("terms")
}

// Course - Course catalog (tenant-scoped)
model Course {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  code        String // e.g., "MATH101", "ENG-201"
  name        String // e.g., "Introduction to Algebra"
  description String?
  category    String? // e.g., "Mathematics", "English", "Science"
  subject     String? // Subject area (can be same as category or more specific)

  // Grade Levels - Array of grade levels that can take this course
  // e.g., ["9", "10", "11", "12"] or ["K", "1", "2"] for elementary
  gradeLevels String[] @default([]) @map("grade_levels")

  // Credits/Hours
  credits Decimal? // e.g., 3.0, 4.5
  hours   Decimal? // Contact hours

  // Status
  status String @default("active") // 'active' | 'archived' | 'draft'

  // Metadata
  prerequisites String? // Description or course codes
  objectives    String? // Learning objectives

  // Audit Fields
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classes Class[]

  @@unique([tenantId, code]) // Unique course code per tenant
  @@index([tenantId])
  @@index([status])
  @@index([category])
  @@index([code])
  @@map("courses")
}

// Class - Course offering in a specific term (section/classroom)
model Class {
  id             String @id @default(uuid())
  courseId       String @map("course_id")
  termId         String @map("term_id")
  academicYearId String @map("academic_year_id") // Denormalized for easier queries

  // Section Information
  section String // e.g., "A", "B", "Section 1", "Morning"
  name    String? // Optional custom name (e.g., "Algebra I - Advanced Section")

  // Capacity and Enrollment
  capacity          Int @default(30) // Maximum number of students
  currentEnrollment Int @default(0) @map("current_enrollment") // Current number enrolled

  // Schedule - JSONB for flexibility (can store complex schedules)
  // Example: { "days": ["Monday", "Wednesday", "Friday"], "time": "09:00-10:30", "room": "Room 101" }
  // Or: [{ "day": "Monday", "startTime": "09:00", "endTime": "10:30", "room": "Room 101" }, ...]
  schedule Json?

  // Location
  room String? // Room/location identifier

  // Status
  status String @default("active") // 'active' | 'full' | 'cancelled' | 'archived'

  // Additional Information
  description String?

  // Audit Fields
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  term          Term           @relation(fields: [termId], references: [id], onDelete: Cascade)
  academicYear  AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classTeachers ClassTeacher[] // Teacher assignments
  enrollments   Enrollment[] // Student enrollments
  assessments   Assessment[] // Assessments/assignments

  @@unique([courseId, termId, section]) // Unique section per course-term combination
  @@index([courseId])
  @@index([termId])
  @@index([academicYearId])
  @@index([status])
  @@index([room])
  @@map("classes")
}

// ClassTeacher - Many-to-many: Teachers assigned to classes
// Note: This assumes UserTenant (profile) represents teachers
// For now, we'll use userTenantId to reference the teacher's profile
model ClassTeacher {
  id           String @id @default(uuid())
  classId      String @map("class_id")
  userTenantId String @map("user_tenant_id") // Teacher's profile (UserTenant)

  // Role/Assignment Type
  role String @default("teacher") // 'teacher' | 'assistant' | 'co-teacher' | 'substitute'

  // Assignment Dates
  assignedAt   DateTime  @default(now()) @map("assigned_at")
  assignedBy   String?   @map("assigned_by") // Admin who assigned
  unassignedAt DateTime? @map("unassigned_at")
  unassignedBy String?   @map("unassigned_by")

  // Status
  isActive Boolean @default(true) @map("is_active")

  // Relations
  class      Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  userTenant UserTenant @relation(fields: [userTenantId], references: [id], onDelete: Cascade)

  @@unique([classId, userTenantId]) // One assignment per teacher per class
  @@index([classId])
  @@index([userTenantId])
  @@index([isActive])
  @@map("class_teachers")
}

// ============================================
// Assessment and Grading Models
// ============================================
//
// Schema Design Notes:
//
// 1. GradingSystem:
//    - Tenant-scoped grading systems (percentage, letter grade, GPA, pass/fail, custom)
//    - Flexible grade scale stored as JSONB
//    - Default grading system per tenant
//
// 2. Assessment:
//    - Assessment/assignment definition (quiz, test, project, homework, etc.)
//    - Belongs to a class
//    - Can be linked to a grading system
//    - Assessment type, weight, due date, max points
//
// 3. Grade:
//    - Individual student grade for an assessment
//    - Links Enrollment (student in class) to Assessment
//    - Points earned, percentage, letter grade
//    - Status (draft, submitted, graded, late)
//
// See: _requirements/features-functionality.md for grade and assessment requirements
// ============================================

// GradingSystem - Grading systems (percentage, letter grade, GPA, pass/fail, custom)
model GradingSystem {
  id         String @id @default(uuid())
  tenantId   String @map("tenant_id")
  name       String // e.g., "Standard Letter Grades", "Percentage-Based", "4.0 GPA Scale"
  systemType String @map("system_type") // 'percentage' | 'letter_grade' | 'gpa' | 'pass_fail' | 'custom'

  // Grade Scale - JSONB for flexible grade definitions
  // Example for letter grades:
  // {
  //   "A+": {"min": 97, "max": 100, "points": 4.0},
  //   "A": {"min": 93, "max": 96, "points": 4.0},
  //   "A-": {"min": 90, "max": 92, "points": 3.7},
  //   ...
  // }
  // Example for percentage:
  // {
  //   "pass": {"min": 60, "max": 100},
  //   "fail": {"min": 0, "max": 59}
  // }
  gradeScale Json // Flexible grade scale definitions

  isDefault Boolean @default(false) @map("is_default") // Default grading system for tenant
  isActive  Boolean @default(true) @map("is_active")

  description String?

  // Audit Fields
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assessments Assessment[]

  @@unique([tenantId, name]) // Unique name per tenant
  @@index([tenantId])
  @@index([systemType])
  @@index([isDefault])
  @@index([isActive])
  @@map("grading_systems")
}

// Assessment - Assessment/assignment definition (quiz, test, project, homework, etc.)
model Assessment {
  id             String @id @default(uuid())
  classId        String @map("class_id")
  academicYearId String @map("academic_year_id") // Denormalized for easier queries
  termId         String @map("term_id") // Denormalized for easier queries

  // Assessment Information
  name        String // e.g., "Midterm Exam", "Final Project", "Chapter 5 Quiz"
  description String?
  type        String // 'quiz' | 'test' | 'exam' | 'project' | 'homework' | 'assignment' | 'lab' | 'presentation' | 'participation' | 'custom'

  // Grading Details
  maxPoints       Decimal  @map("max_points") // Maximum points possible (e.g., 100.0)
  weight          Decimal? // Weight percentage for final grade (e.g., 25.0 for 25%)
  gradingSystemId String?  @map("grading_system_id") // Optional link to grading system

  // Dates
  assignedDate DateTime? @map("assigned_date")
  dueDate      DateTime? @map("due_date")
  gradedDate   DateTime? @map("graded_date")

  // Status
  status String @default("draft") // 'draft' | 'published' | 'in_progress' | 'graded' | 'archived'

  // Additional Information
  instructions String? // Instructions for students
  rubric       Json? // Grading rubric (JSONB)

  // Audit Fields
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  class         Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  academicYear  AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  term          Term           @relation(fields: [termId], references: [id], onDelete: Cascade)
  gradingSystem GradingSystem? @relation(fields: [gradingSystemId], references: [id], onDelete: SetNull)
  grades        Grade[]

  @@index([classId])
  @@index([academicYearId])
  @@index([termId])
  @@index([status])
  @@index([dueDate])
  @@index([type])
  @@map("assessments")
}

// Grade - Individual student grade for an assessment
model Grade {
  id           String @id @default(uuid())
  enrollmentId String @map("enrollment_id")
  assessmentId String @map("assessment_id")

  // Grade Values
  pointsEarned Decimal? @map("points_earned") // Points earned (e.g., 85.5)
  percentage   Decimal? // Percentage (e.g., 85.5)
  letterGrade  String?  @map("letter_grade") // Letter grade (e.g., "A", "B+", "P")
  gpaPoints    Decimal? @map("gpa_points") // GPA points (e.g., 3.7)

  // Status
  status String @default("draft") // 'draft' | 'submitted' | 'graded' | 'late' | 'excused' | 'missing'

  // Submission Information
  submittedAt DateTime? @map("submitted_at")
  gradedAt    DateTime? @map("graded_at")
  gradedBy    String?   @map("graded_by") // UserTenant ID of grader

  // Feedback
  feedback    String? // Teacher feedback/comments
  rubricScore Json?   @map("rubric_score") // Rubric scores (JSONB)

  // Additional Information
  notes String?

  // Audit Fields
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, assessmentId]) // One grade per student per assessment
  @@index([enrollmentId])
  @@index([assessmentId])
  @@index([status])
  @@index([submittedAt])
  @@index([gradedAt])
  @@map("grades")
}

// ============================================
// Audit Logging Models
// ============================================
//
// Schema Design Notes:
//
// 1. AuditLog:
//    - Comprehensive audit trail for all system actions
//    - Tenant-scoped with platform-level logs
//    - Tracks user actions, data changes, security events
//    - Structured metadata for different event types
//    - Indexed for efficient querying and reporting
//
// 2. Event Types:
//    - User actions (login, logout, profile changes)
//    - Data modifications (create, update, delete)
//    - Security events (permission changes, role assignments, breaches)
//    - System events (migrations, configuration changes)
//
// See: _actions/multi-tenancy-security-strategy.md for audit requirements
// See: _requirements/security-compliance.md for compliance requirements
// ============================================

// AuditLog - Comprehensive audit trail for all system actions
model AuditLog {
  id       String  @id @default(uuid())
  tenantId String? @map("tenant_id") // Null for platform-level events

  // Event Information
  eventType  String  @map("event_type") // 'user_action' | 'data_change' | 'security_event' | 'system_event' | 'authentication' | 'authorization' | 'custom'
  action     String // e.g., 'login', 'create', 'update', 'delete', 'assign_role', 'grant_permission'
  resource   String? // Resource type (e.g., 'user', 'student', 'grade', 'role')
  resourceId String? @map("resource_id") // Resource ID (if applicable)

  // Actor Information
  actorId        String? @map("actor_id") // User ID (global user, not profile)
  actorProfileId String? @map("actor_profile_id") // UserTenant ID (profile context)
  actorRole      String? @map("actor_role") // Role name at time of action
  actorEmail     String? @map("actor_email") // Email for audit trail (even if user deleted)

  // Request Information
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  requestId String? @map("request_id") // Request trace ID
  sessionId String? @map("session_id") // Session ID

  // Event Details
  description String // Human-readable description
  metadata    Json? // Additional event-specific data (JSONB)
  changes     Json? // Before/after changes for data modifications (JSONB)

  // Result Information
  status       String  @default("success") // 'success' | 'failure' | 'error' | 'warning'
  errorCode    String? @map("error_code")
  errorMessage String? @map("error_message")

  // Timestamp
  timestamp DateTime @default(now())

  // Relations
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([eventType])
  @@index([action])
  @@index([resource])
  @@index([resourceId])
  @@index([actorId])
  @@index([actorProfileId])
  @@index([timestamp])
  @@index([status])
  @@index([ipAddress])
  @@index([tenantId, timestamp]) // Composite for tenant-specific queries
  @@index([eventType, timestamp]) // Composite for event type queries
  @@index([actorId, timestamp]) // Composite for user activity queries
  @@map("audit_logs")
}

// ============================================
// Communication Models
// ============================================
//
// Schema Design Notes:
//
// 1. Announcement:
//    - School-wide or class-specific announcements
//    - Tenant-scoped
//    - Can target specific audiences (all, students, parents, teachers, etc.)
//    - Status (draft, published, archived)
//    - Priority levels (normal, important, urgent)
//
// 2. Message:
//    - Direct messages between users (profiles)
//    - Tenant-scoped conversations
//    - Thread-based messaging
//    - Read/unread status
//    - Can be sent to individuals or groups
//
// See: _requirements/features-functionality.md for communication requirements
// ============================================

// Announcement - School-wide or class-specific announcements
model Announcement {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  // Target Audience
  targetType String   @map("target_type") // 'all' | 'students' | 'parents' | 'teachers' | 'staff' | 'class' | 'grade_level' | 'custom'
  targetIds  String[] @default([]) @map("target_ids") // Class IDs, grade levels, or user IDs for custom targets

  // Announcement Content
  title   String
  content String // Main announcement content
  summary String? // Brief summary/preview

  // Priority and Status
  priority String @default("normal") // 'normal' | 'important' | 'urgent'
  status   String @default("draft") // 'draft' | 'published' | 'archived'

  // Scheduling
  publishAt DateTime? @map("publish_at") // Scheduled publish time
  expiresAt DateTime? @map("expires_at") // Expiration date

  // Additional Information
  attachments Json? @default("[]") // File attachments (JSONB array)
  metadata    Json? // Additional metadata (JSONB)

  // Audit Fields
  createdBy   String?   @map("created_by") // UserTenant ID of creator
  updatedBy   String?   @map("updated_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  publishedAt DateTime? @map("published_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([targetType])
  @@index([status])
  @@index([priority])
  @@index([publishAt])
  @@index([createdAt])
  @@map("announcements")
}

// Message - Direct messages between users (profiles)
model Message {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  // Thread Information
  threadId String? @map("thread_id") // Parent message ID for replies (null for top-level)

  // Sender and Recipients
  senderId     String   @map("sender_id") // UserTenant ID of sender
  recipientIds String[] @default([]) @map("recipient_ids") // UserTenant IDs of recipients

  // Message Content
  subject     String? // Optional subject line
  content     String // Message content
  contentType String  @default("text") @map("content_type") // 'text' | 'html' | 'markdown'

  // Status
  status String @default("sent") // 'draft' | 'sent' | 'delivered' | 'read' | 'archived'

  // Additional Information
  attachments Json? @default("[]") // File attachments (JSONB array)
  metadata    Json? // Additional metadata (JSONB)

  // Audit Fields
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  sentAt    DateTime? @map("sent_at")
  readAt    DateTime? @map("read_at")

  // Relations
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sender       UserTenant           @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  thread       Message?             @relation("MessageThread", fields: [threadId], references: [id], onDelete: Cascade)
  replies      Message[]            @relation("MessageThread")
  readReceipts MessageReadReceipt[]

  // Note: recipientIds is an array of UserTenant IDs - handled at application level
  // For many-to-many, use MessageRecipient junction table if needed

  @@index([tenantId])
  @@index([senderId])
  @@index([threadId])
  @@index([status])
  @@index([createdAt])
  @@index([sentAt])
  @@map("messages")
}

// MessageReadReceipt - Track read status for messages
model MessageReadReceipt {
  id        String @id @default(uuid())
  messageId String @map("message_id")
  readerId  String @map("reader_id") // UserTenant ID of reader

  readAt DateTime @default(now()) @map("read_at")

  // Relations
  message Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reader  UserTenant @relation(fields: [readerId], references: [id], onDelete: Cascade)

  @@unique([messageId, readerId]) // One read receipt per message per reader
  @@index([messageId])
  @@index([readerId])
  @@index([readAt])
  @@map("message_read_receipts")
}

// ============================================
// JWT Secret Management Models
// ============================================
//
// Schema Design Notes:
//
// 1. School-Specific JWT Secrets:
//    - Each school has its own unique JWT signing secret
//    - Secrets are automatically generated when schools are created
//    - Secrets are encrypted at rest in the database
//    - Only platform admins can access secrets
//    - Schools cannot access their own secrets
//
// 2. Secret Rotation:
//    - Scheduled rotation (every 90-180 days)
//    - Emergency rotation (for security breaches)
//    - Graceful rotation (keep last 2 secrets for token validation)
//
// See: _actions/multi-tenancy-security-strategy.md for complete JWT secret design
// ============================================

// School JWT Configuration - JWT secret management for each school
model TenantJWTConfig {
  id                 String   @id @default(uuid())
  tenantId           String   @unique @map("tenant_id")
  jwtSecret          String   @map("jwt_secret") // Encrypted at rest
  secretSource       String   @default("auto_generated") @map("secret_source") // 'auto_generated' | 'environment_variable' | 'manual_input'
  secretRotationDate DateTime @default(now()) @map("secret_rotation_date")
  previousSecrets    Json     @default("[]") @map("previous_secrets") // Encrypted previous secrets (keep last 2 for graceful rotation)

  // Rotation tracking
  rotationReason    String? @map("rotation_reason") // 'scheduled' | 'emergency' | 'breach_response' | 'manual'
  emergencyRotation Boolean @default(false) @map("emergency_rotation")

  // Access Control
  managedBy           String  @default("platform_admin") @map("managed_by") // 'platform_admin' | 'architect'
  accessibleBySchools Boolean @default(false) @map("accessible_by_schools") // Schools cannot access secrets

  // Audit Fields
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([secretRotationDate])
  @@map("tenant_jwt_configs")
}

// ============================================
// User-Tenant Profile Models
// ============================================
//
// Schema Design Notes:
//
// 1. User-Tenant Relationship (Profile):
//    - Each school-role combination is a "profile"
//    - User can have multiple profiles (one per school, potentially multiple roles per school)
//    - Profile-specific permissions can override role permissions
//    - Profile-level suspension capability
//    - Invitation-based addition support
//
// 2. Profile Permissions:
//    - Profile-specific permissions can override role permissions
//    - Grant or deny permissions explicitly per profile
//
// See: _actions/multi-tenancy-security-strategy.md for complete security design
// ============================================

// User-Tenant Relationship - Profile (many-to-many: user can belong to multiple schools)
model UserTenant {
  id       String @id @default(uuid())
  userId   String @map("user_id")
  tenantId String @map("tenant_id")

  // Profile Status
  status           String    @default("pending") // 'active' | 'inactive' | 'pending' | 'suspended'
  suspended        Boolean   @default(false)
  suspendedAt      DateTime? @map("suspended_at")
  suspendedBy      String?   @map("suspended_by")
  suspensionReason String?   @map("suspension_reason")

  // Invitation Fields (for invitation-based addition)
  invitationToken      String?   @map("invitation_token")
  invitationExpiresAt  DateTime? @map("invitation_expires_at")
  invitationAcceptedAt DateTime? @map("invitation_accepted_at")

  // Audit Fields
  addedBy String?  @map("added_by") // Admin who added user to school
  addedAt DateTime @default(now()) @map("added_at")

  // Relations
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userTenantRoles       UserTenantRole[] // User can have multiple roles per school
  userTenantPermissions UserTenantPermission[] // Profile-specific permissions (override role permissions)
  sessions              Session[]
  classTeachers         ClassTeacher[] // Teacher assignments to classes
  students              Student[] // Student profiles (for students)
  sentMessages          Message[]              @relation("MessageSender") // Messages sent by this profile
  messageReadReceipts   MessageReadReceipt[] // Read receipts for messages

  @@unique([userId, tenantId]) // One relationship per user-tenant pair
  @@index([userId])
  @@index([tenantId])
  @@index([status])
  @@index([suspended])
  @@index([invitationToken])
  @@map("user_tenants")
}

// User Tenant Role - Profile can have multiple roles per school
model UserTenantRole {
  id           String   @id @default(uuid())
  userTenantId String   @map("user_tenant_id")
  roleId       String   @map("role_id")
  isPrimary    Boolean  @default(false) @map("is_primary") // Primary role for the profile
  assignedAt   DateTime @default(now()) @map("assigned_at")
  assignedBy   String?  @map("assigned_by")

  userTenant UserTenant @relation(fields: [userTenantId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userTenantId, roleId])
  @@index([userTenantId])
  @@index([roleId])
  @@index([isPrimary])
  @@map("user_tenant_roles")
}

// User Tenant Permissions - Profile-specific permissions (override role permissions)
model UserTenantPermission {
  id           String   @id @default(uuid())
  userTenantId String   @map("user_tenant_id")
  permissionId String   @map("permission_id")
  granted      Boolean  @default(true) // true = granted, false = denied (override)
  grantedAt    DateTime @default(now()) @map("granted_at")
  grantedBy    String?  @map("granted_by")

  userTenant UserTenant @relation(fields: [userTenantId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userTenantId, permissionId])
  @@index([userTenantId])
  @@index([permissionId])
  @@map("user_tenant_permissions")
}

// ============================================
// Roles and Permissions Models
// ============================================
//
// Schema Design Notes:
//
// 1. Roles:
//    - Platform roles (Architect, SuperAdmin) - tenantId = null
//    - System roles (Owner, Management, Teacher, etc.) - tenantId = null (global)
//    - Custom roles - tenantId = UUID (school-specific)
//    - Each role has clearance level (0-10) and role type
//
// 2. Permissions:
//    - 300+ granular permissions (resource.action format)
//    - Context-aware permissions (e.g., 'students.edit.own_classes')
//    - Permissions assigned to roles, can be overridden per profile
//
// See: _requirements/access-control.md for role hierarchy and clearance levels
// See: _requirements/permissions.md for complete permission list
// See: _actions/role-permissions-management.md for permission pool inheritance and custom role constraints
// ============================================

// Roles - System roles (platform) and custom roles (school-specific)
// 
// Role Types:
// - 'platform': Platform-level roles (Architect, SuperAdmin) - tenantId = null, name globally unique
// - 'system': System-level roles (Owner, Management, Teacher, etc.) - tenantId = null, name globally unique
// - 'custom': School-specific custom roles - tenantId = UUID, name unique per tenant
//
// Note: For platform/system roles (tenantId = null), ensure name is globally unique at application level.
// Prisma's @@unique([name, tenantId]) allows multiple NULL values, so application-level validation is needed.
model Role {
  id             String  @id @default(uuid())
  name           String // Globally unique for platform/system roles, tenant-specific for custom roles
  description    String?
  roleType       String  @map("role_type") // 'platform' | 'system' | 'custom'
  clearanceLevel Int     @map("clearance_level") // 0-10 (Architect=10, SuperAdmin=9, Owner=8, etc.)
  isSystemRole   Boolean @default(false) @map("is_system_role") // True for predefined roles
  tenantId       String? @map("tenant_id") // Null for platform/system roles, required for custom roles
  isActive       Boolean @default(true) @map("is_active")

  // Audit Fields
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userTenantRoles UserTenantRole[]
  rolePools       RolePermissionPool[]

  @@unique([name, tenantId]) // Name unique per tenant (for custom roles), application-level check needed for platform/system roles
  @@index([roleType])
  @@index([clearanceLevel])
  @@index([tenantId])
  @@index([isSystemRole])
  @@index([roleType, name]) // For platform/system role name uniqueness checks
  @@map("roles")
}

// Permissions - The 300+ granular permissions
// Structured metadata for UI rendering: key (name), label (display), description (details)
model Permission {
  id          String  @id @default(uuid())
  name        String  @unique // Key/identifier (e.g., 'students.view', 'grades.edit', 'platform.override')
  label       String // Human-readable display name (e.g., 'View Students', 'Edit Grades')
  description String? // Detailed description for UI rendering and tooltips
  resource    String // e.g., 'students', 'grades', 'platform'
  action      String // e.g., 'view', 'edit', 'create', 'delete'
  context     String? // e.g., 'own_classes', 'children', 'department'
  category    String // e.g., 'academic', 'administrative', 'platform', 'financial'

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  rolePermissions       RolePermission[]
  userTenantPermissions UserTenantPermission[]
  poolPermissions       PermissionPoolPermission[]

  @@index([resource])
  @@index([action])
  @@index([category])
  @@index([resource, action]) // For fast permission lookups
  @@map("permissions")
}

// Role Permissions - Many-to-many: Roles have permissions
model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  grantedAt    DateTime @default(now()) @map("granted_at")
  grantedBy    String?  @map("granted_by")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// Permission Pools - Predefined sets of permissions grouped by clearance level
// Custom roles can only inherit permissions from pools matching their clearance level or below
model PermissionPool {
  id             String  @id @default(uuid())
  name           String // e.g., "Level10_PlatformArchitect", "Level7_SchoolManagement"
  clearanceLevel Int     @map("clearance_level") // 0-10
  description    String?
  isSystemPool   Boolean @default(true) @map("is_system_pool") // True for predefined pools
  tenantId       String? @map("tenant_id") // Null for system pools, can be set for tenant-specific pools

  // Audit Fields
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant?                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  poolPermissions PermissionPoolPermission[]
  rolePools       RolePermissionPool[]

  @@unique([name, tenantId]) // Name unique per tenant (for custom pools)
  @@index([clearanceLevel])
  @@index([isSystemPool])
  @@index([tenantId])
  @@map("permission_pools")
}

// Permission Pool Permissions - Many-to-many: Permission pools contain permissions
model PermissionPoolPermission {
  id           String   @id @default(uuid())
  poolId       String   @map("pool_id")
  permissionId String   @map("permission_id")
  addedAt      DateTime @default(now()) @map("added_at")
  addedBy      String?  @map("added_by")

  pool       PermissionPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  permission Permission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([poolId, permissionId])
  @@index([poolId])
  @@index([permissionId])
  @@map("permission_pool_permissions")
}

// Role Permission Pools - Many-to-many: Roles inherit from permission pools
model RolePermissionPool {
  id         String   @id @default(uuid())
  roleId     String   @map("role_id")
  poolId     String   @map("pool_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by")

  role Role           @relation(fields: [roleId], references: [id], onDelete: Cascade)
  pool PermissionPool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([roleId, poolId])
  @@index([roleId])
  @@index([poolId])
  @@map("role_permission_pools")
}

// ============================================
// Student Management Models
// ============================================
//
// Schema Design Notes:
//
// 1. Student:
//    - Links to UserTenant (profile) - represents a student's profile at a school
//    - Tenant-scoped student records
//    - Student number (unique per tenant)
//    - Enrollment status tracking
//    - Flexible JSONB fields for personal, academic, health, emergency contacts
//
// 2. Enrollment:
//    - Links Student to Class (course offering in a term)
//    - Academic year context
//    - Enrollment status (active, dropped, completed, failed)
//    - Final grade and credits earned
//    - Unique per student-class-academic year
//
// See: _requirements/features-functionality.md for student management requirements
// ============================================

// Student - Student profile at a school (linked to UserTenant)
model Student {
  id           String @id @default(uuid())
  tenantId     String @map("tenant_id")
  userTenantId String @map("user_tenant_id") // Student's profile (UserTenant)

  // Student Identification
  studentNumber   String // e.g., "STU-2024-001", unique per tenant
  admissionNumber String?   @map("admission_number")
  admissionDate   DateTime? @map("admission_date")

  // Current Status
  gradeLevel       String? @map("grade_level") // Current grade level (e.g., "9", "10", "K", "1")
  enrollmentStatus String  @default("active") @map("enrollment_status") // 'active' | 'inactive' | 'suspended' | 'graduated' | 'transferred' | 'withdrawn'

  // Flexible Data Fields (JSONB)
  personalInfo      Json? @default("{}") @map("personal_info") // Personal details
  academicInfo      Json? @default("{}") @map("academic_info") // Academic history
  healthInfo        Json? @default("{}") @map("health_info") // Health records, allergies, medications
  emergencyContacts Json? @default("[]") @map("emergency_contacts") // Emergency contact information
  guardianInfo      Json? @default("[]") @map("guardian_info") // Parent/guardian information
  specialNeeds      Json? @default("[]") @map("special_needs") // Special needs, accommodations

  // Status Dates
  enrollmentDate DateTime? @map("enrollment_date")
  graduationDate DateTime? @map("graduation_date")
  withdrawalDate DateTime? @map("withdrawal_date")
  transferDate   DateTime? @map("transfer_date")

  // Audit Fields
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userTenant  UserTenant   @relation(fields: [userTenantId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]

  @@unique([tenantId, studentNumber]) // Unique student number per tenant
  @@index([tenantId])
  @@index([userTenantId])
  @@index([enrollmentStatus])
  @@index([gradeLevel])
  @@index([studentNumber])
  @@map("students")
}

// Enrollment - Student enrollment in a class (course offering)
model Enrollment {
  id             String @id @default(uuid())
  studentId      String @map("student_id")
  classId        String @map("class_id")
  academicYearId String @map("academic_year_id")
  termId         String @map("term_id") // Denormalized for easier queries

  // Enrollment Details
  enrollmentDate DateTime @default(now()) @map("enrollment_date")
  status         String   @default("active") // 'active' | 'dropped' | 'completed' | 'failed'

  // Academic Results
  finalGrade    String?  @map("final_grade") // Final letter grade or percentage
  creditsEarned Decimal? @map("credits_earned") // Credits earned (e.g., 3.0, 4.5)
  gpaPoints     Decimal? @map("gpa_points") // GPA points for this course

  // Additional Information
  notes String?

  // Status Dates
  droppedDate   DateTime? @map("dropped_date")
  completedDate DateTime? @map("completed_date")

  // Audit Fields
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class        Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  term         Term         @relation(fields: [termId], references: [id], onDelete: Cascade)
  grades       Grade[] // Grades/assessments for this enrollment

  @@unique([studentId, classId, academicYearId]) // Unique enrollment per student-class-year
  @@index([studentId])
  @@index([classId])
  @@index([academicYearId])
  @@index([termId])
  @@index([status])
  @@index([enrollmentDate])
  @@map("enrollments")
}

// ============================================
// Tenant (School) Management Models
// ============================================
//
// Schema Design Notes:
//
// 1. Tenants (Schools):
//    - Basic tenant structure for multi-tenant architecture
//    - Each tenant represents a school
//    - Optional email domain for validation
//    - Status tracking (active, pending, suspended)
//    - School-specific settings stored as JSONB
//
// See: _actions/multi-tenancy-security-strategy.md for complete tenant design
// See: _requirements/multi-tenant-architecture.md for architecture details
// ============================================

// Tenants (Schools) - Basic structure for multi-tenant architecture
model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String?  @unique
  emailDomain String?  @map("email_domain") // Optional, for validation
  status      String   @default("pending") // 'active' | 'pending' | 'suspended'
  settings    Json? // School-specific settings (JSONB)
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  roles           Role[]
  userTenants     UserTenant[]
  permissionPools PermissionPool[]
  academicYears   AcademicYear[]
  courses         Course[]
  students        Student[]
  gradingSystems  GradingSystem[]
  announcements   Announcement[]
  messages        Message[]
  auditLogs       AuditLog[]
  jwtConfig       TenantJWTConfig?

  @@index([status])
  @@index([emailDomain])
  @@map("tenants")
}

// ============================================
// User Management Models
// ============================================
//
// Schema Design Notes:
//
// 1. Users:
//    - Single user account can belong to multiple schools (many-to-many)
//    - Each user has one email + password + MFA (account-level)
//    - Password history tracked for reuse prevention
//    - Login attempts tracked for rate limiting and lockout
//
// 2. Security:
//    - Password history for reuse prevention
//    - Login attempts for rate limiting
//    - Session management with profile context
//    - Audit fields (created_by, updated_by) for tracking
//
// See: _actions/multi-tenancy-security-strategy.md for complete security design
// See: _requirements/access-control.md for role hierarchy and clearance levels
// ============================================

// Users - Core user account information
model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String? @map("password_hash") // bcrypt hash, nullable for invitation-based accounts
  firstName    String? @map("first_name")
  lastName     String? @map("last_name")
  phone        String?

  // Account Status
  isActive        Boolean   @default(true) @map("is_active")
  isVerified      Boolean   @default(false) @map("is_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")

  // Security Fields
  loginAttempts     Int       @default(0) @map("login_attempts")
  lockedUntil       DateTime? @map("locked_until") // Account lockout timestamp
  passwordChangedAt DateTime? @map("password_changed_at") // For password expiration check
  lastLoginAt       DateTime? @map("last_login_at")

  // Password Reset
  passwordResetToken     String?   @map("password_reset_token")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")

  // Audit Fields
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  createdByUser User?  @relation("UserCreated", fields: [createdBy], references: [id])
  updatedByUser User?  @relation("UserUpdated", fields: [updatedBy], references: [id])
  createdUsers  User[] @relation("UserCreated")
  updatedUsers  User[] @relation("UserUpdated")

  passwordHistories PasswordHistory[]
  loginAttemptsList LoginAttempt[]
  userTenants       UserTenant[]
  sessions          Session[]

  @@index([email])
  @@index([isActive])
  @@index([isVerified])
  @@map("users")
}

// Password History - For password reuse prevention
model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  passwordHash String   @map("password_hash") // Encrypted previous password
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("password_histories")
}

// Login Attempts - For rate limiting and security monitoring
model LoginAttempt {
  id            String   @id @default(uuid())
  userId        String?  @map("user_id") // Nullable for failed attempts with unknown user
  email         String // For tracking failed attempts
  ipAddress     String   @map("ip_address")
  userAgent     String?  @map("user_agent")
  success       Boolean  @default(false)
  failureReason String?  @map("failure_reason")
  createdAt     DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, createdAt])
  @@index([userId, createdAt])
  @@index([ipAddress, createdAt])
  @@index([success])
  @@map("login_attempts")
}

// Sessions - Active user sessions for session management
model Session {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  userTenantId      String    @map("user_tenant_id") // Profile ID (current context)
  token             String    @unique // JWT token or session token
  ipAddress         String?   @map("ip_address")
  userAgent         String?   @map("user_agent")
  deviceFingerprint String?   @map("device_fingerprint")
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userTenant UserTenant @relation(fields: [userTenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userTenantId])
  @@index([token])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("sessions")
}

// Main Prisma Schema File
// This file is the entry point and contains the datasource and generator configuration
// All models are organized in separate files by context in the same directory

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
