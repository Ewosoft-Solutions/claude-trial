{
  "name": "@workspace/database",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs",
      "default": "./dist/client.js"
    },
    "./rls": {
      "types": "./dist/rls/index.d.ts",
      "import": "./dist/rls/index.js",
      "require": "./dist/rls/index.cjs",
      "default": "./dist/rls/index.js"
    }
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/scripts/seed.ts",
    "db:seed:dev": "ENABLE_DEV_SEEDS=true tsx prisma/scripts/dev/personas.ts",
    "db:seed:academics": "ENABLE_DEV_SEEDS=true tsx prisma/scripts/dev/academics.ts",
    "db:seed:ops": "ENABLE_DEV_SEEDS=true tsx prisma/scripts/dev/operational.ts",
    "db:seed:dev:full": "pnpm run db:seed && pnpm run db:seed:dev && pnpm run db:seed:academics && pnpm run db:seed:ops",
    "db:verify": "tsx prisma/scripts/verify-seed.ts",
    "db:rls:check": "prisma db execute --file prisma/scripts/rls-coverage-check.sql",
    "db:rls:enforce": "prisma db execute --file prisma/scripts/rls-enforce.sql",
    "db:rls:proof": "tsx prisma/scripts/rls-prisma-proof.ts",
    "db:rls:verify": "tsx prisma/scripts/verify-app-runtime.ts",
    "db:studio": "prisma studio",
    "dev": "tsup src/* --watch",
    "prebuild": "npm run db:generate",
    "predev": "npm run db:generate",
    "format": "prisma format",
    "lint": "eslint . --max-warnings 0",
    "build": "tsup src"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.31.0",
    "prisma": "^7.1.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "tsx": "4.19.1",
    "typescript": "^5.9.3"
  }
}
