// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Core User Management Tables
// ============================================
//
// Schema Design Notes:
//
// 1. Users:
//    - Single user account can belong to multiple schools (many-to-many)
//    - Each user has one email + password + MFA (account-level)
//    - Password history tracked for reuse prevention
//    - Login attempts tracked for rate limiting and lockout
//
// 2. Roles:
//    - Platform roles (Architect, SuperAdmin) - tenantId = null
//    - System roles (Owner, Management, Teacher, etc.) - tenantId = null (global)
//    - Custom roles - tenantId = UUID (school-specific)
//    - Each role has clearance level (0-10) and role type
//
// 3. Permissions:
//    - 300+ granular permissions (resource.action format)
//    - Context-aware permissions (e.g., 'students.edit.own_classes')
//    - Permissions assigned to roles, can be overridden per profile
//
// 4. User-Tenant Relationship (Profile):
//    - Each school-role combination is a "profile"
//    - User can have multiple profiles (one per school, potentially multiple roles per school)
//    - Profile-specific permissions can override role permissions
//    - Profile-level suspension capability
//    - Invitation-based addition support
//
// 5. Security:
//    - Password history for reuse prevention
//    - Login attempts for rate limiting
//    - Session management with profile context
//    - Audit fields (created_by, updated_by) for tracking
//
// See: _actions/multi-tenancy-security-strategy.md for complete security design
// See: _requirements/access-control.md for role hierarchy and clearance levels
// See: _requirements/permissions.md for complete permission list
// ============================================

// Users - Core user account information
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String?  @map("password_hash") // bcrypt hash, nullable for invitation-based accounts
  firstName     String?  @map("first_name")
  lastName      String?  @map("last_name")
  phone         String?
  
  // Account Status
  isActive      Boolean  @default(true) @map("is_active")
  isVerified    Boolean  @default(false) @map("is_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")
  
  // Security Fields
  loginAttempts Int      @default(0) @map("login_attempts")
  lockedUntil   DateTime? @map("locked_until") // Account lockout timestamp
  passwordChangedAt DateTime? @map("password_changed_at") // For password expiration check
  lastLoginAt   DateTime? @map("last_login_at")
  
  // Password Reset
  passwordResetToken String? @map("password_reset_token")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")
  
  // Audit Fields
  createdBy     String?  @map("created_by")
  updatedBy     String?  @map("updated_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  // Relations
  createdByUser User? @relation("UserCreated", fields: [createdBy], references: [id])
  updatedByUser User? @relation("UserUpdated", fields: [updatedBy], references: [id])
  createdUsers User[] @relation("UserCreated")
  updatedUsers User[] @relation("UserUpdated")
  
  passwordHistories PasswordHistory[]
  loginAttemptsList LoginAttempt[]
  userTenants UserTenant[]
  sessions Session[]
  
  @@map("users")
  @@index([email])
  @@index([isActive])
  @@index([isVerified])
}

// Password History - For password reuse prevention
model PasswordHistory {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  passwordHash String  @map("password_hash") // Encrypted previous password
  createdAt   DateTime @default(now()) @map("created_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("password_histories")
  @@index([userId, createdAt])
}

// Login Attempts - For rate limiting and security monitoring
model LoginAttempt {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id") // Nullable for failed attempts with unknown user
  email       String   // For tracking failed attempts
  ipAddress   String   @map("ip_address")
  userAgent   String?  @map("user_agent")
  success     Boolean  @default(false)
  failureReason String? @map("failure_reason")
  createdAt   DateTime @default(now()) @map("created_at")
  
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("login_attempts")
  @@index([email, createdAt])
  @@index([userId, createdAt])
  @@index([ipAddress, createdAt])
  @@index([success])
}

// Roles - System roles (platform) and custom roles (school-specific)
// 
// Role Types:
// - 'platform': Platform-level roles (Architect, SuperAdmin) - tenantId = null, name globally unique
// - 'system': System-level roles (Owner, Management, Teacher, etc.) - tenantId = null, name globally unique
// - 'custom': School-specific custom roles - tenantId = UUID, name unique per tenant
//
// Note: For platform/system roles (tenantId = null), ensure name is globally unique at application level.
// Prisma's @@unique([name, tenantId]) allows multiple NULL values, so application-level validation is needed.
model Role {
  id            String   @id @default(uuid())
  name          String   // Globally unique for platform/system roles, tenant-specific for custom roles
  description   String?
  roleType      String   @map("role_type") // 'platform' | 'system' | 'custom'
  clearanceLevel Int     @map("clearance_level") // 0-10 (Architect=10, SuperAdmin=9, Owner=8, etc.)
  isSystemRole  Boolean  @default(false) @map("is_system_role") // True for predefined roles
  tenantId      String?  @map("tenant_id") // Null for platform/system roles, required for custom roles
  isActive      Boolean  @default(true) @map("is_active")
  
  // Audit Fields
  createdBy     String?  @map("created_by")
  updatedBy     String?  @map("updated_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  // Relations
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userTenantRoles UserTenantRole[]
  
  @@map("roles")
  @@unique([name, tenantId]) // Name unique per tenant (for custom roles), application-level check needed for platform/system roles
  @@index([roleType])
  @@index([clearanceLevel])
  @@index([tenantId])
  @@index([isSystemRole])
  @@index([roleType, name]) // For platform/system role name uniqueness checks
}

// Permissions - The 300+ granular permissions
model Permission {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., 'students.view', 'grades.edit', 'platform.override'
  description String?
  resource    String   // e.g., 'students', 'grades', 'platform'
  action      String   // e.g., 'view', 'edit', 'create', 'delete'
  context     String? // e.g., 'own_classes', 'children', 'department'
  category    String   // e.g., 'academic', 'administrative', 'platform', 'financial'
  
  createdAt   DateTime @default(now()) @map("created_at")
  
  // Relations
  rolePermissions RolePermission[]
  userTenantPermissions UserTenantPermission[]
  
  @@map("permissions")
  @@index([resource])
  @@index([action])
  @@index([category])
  @@index([resource, action]) // For fast permission lookups
}

// Role Permissions - Many-to-many: Roles have permissions
model RolePermission {
  id          String   @id @default(uuid())
  roleId      String   @map("role_id")
  permissionId String @map("permission_id")
  grantedAt   DateTime @default(now()) @map("granted_at")
  grantedBy   String?  @map("granted_by")
  
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@map("role_permissions")
  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// User-Tenant Relationship - Profile (many-to-many: user can belong to multiple schools)
model UserTenant {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  tenantId    String   @map("tenant_id")
  
  // Profile Status
  status      String   @default("pending") // 'active' | 'inactive' | 'pending' | 'suspended'
  suspended   Boolean  @default(false)
  suspendedAt DateTime? @map("suspended_at")
  suspendedBy String?  @map("suspended_by")
  suspensionReason String? @map("suspension_reason")
  
  // Invitation Fields (for invitation-based addition)
  invitationToken String? @map("invitation_token")
  invitationExpiresAt DateTime? @map("invitation_expires_at")
  invitationAcceptedAt DateTime? @map("invitation_accepted_at")
  
  // Audit Fields
  addedBy     String?  @map("added_by") // Admin who added user to school
  addedAt     DateTime @default(now()) @map("added_at")
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userTenantRoles UserTenantRole[] // User can have multiple roles per school
  userTenantPermissions UserTenantPermission[] // Profile-specific permissions (override role permissions)
  sessions Session[]
  
  @@map("user_tenants")
  @@unique([userId, tenantId]) // One relationship per user-tenant pair
  @@index([userId])
  @@index([tenantId])
  @@index([status])
  @@index([suspended])
  @@index([invitationToken])
}

// User Tenant Role - Profile can have multiple roles per school
model UserTenantRole {
  id          String   @id @default(uuid())
  userTenantId String @map("user_tenant_id")
  roleId      String   @map("role_id")
  isPrimary   Boolean  @default(false) @map("is_primary") // Primary role for the profile
  assignedAt  DateTime @default(now()) @map("assigned_at")
  assignedBy  String?  @map("assigned_by")
  
  userTenant UserTenant @relation(fields: [userTenantId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  @@map("user_tenant_roles")
  @@unique([userTenantId, roleId])
  @@index([userTenantId])
  @@index([roleId])
  @@index([isPrimary])
}

// User Tenant Permissions - Profile-specific permissions (override role permissions)
model UserTenantPermission {
  id          String   @id @default(uuid())
  userTenantId String @map("user_tenant_id")
  permissionId String @map("permission_id")
  granted     Boolean  @default(true) // true = granted, false = denied (override)
  grantedAt   DateTime @default(now()) @map("granted_at")
  grantedBy   String?  @map("granted_by")
  
  userTenant UserTenant @relation(fields: [userTenantId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@map("user_tenant_permissions")
  @@unique([userTenantId, permissionId])
  @@index([userTenantId])
  @@index([permissionId])
}

// Sessions - Active user sessions for session management
model Session {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  userTenantId String @map("user_tenant_id") // Profile ID (current context)
  token       String   @unique // JWT token or session token
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  deviceFingerprint String? @map("device_fingerprint")
  expiresAt   DateTime @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime @default(now()) @map("created_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userTenant UserTenant @relation(fields: [userTenantId], references: [id], onDelete: Cascade)
  
  @@map("sessions")
  @@index([userId])
  @@index([userTenantId])
  @@index([token])
  @@index([expiresAt])
  @@index([revokedAt])
}

// Tenants (Schools) - Will be defined in tenant management tables
model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String?  @unique
  emailDomain String?  @map("email_domain") // Optional, for validation
  status      String   @default("pending") // 'active' | 'pending' | 'suspended'
  settings    Json?    // School-specific settings (JSONB)
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // Relations
  roles Role[]
  userTenants UserTenant[]
  
  @@map("tenants")
  @@index([status])
  @@index([emailDomain])
}
