// Main Prisma Schema File
// This file is the entry point and contains the datasource and generator configuration
// All models are organized in separate files by context in the same directory

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas = ["academic-structure", "admissions", "audit-logging", "communication", "finance", "jwt-secrets", "profile", "roles-permissions", "security-policy", "student-management", "tenant", "user-management"]
}


