// Main Prisma Schema File
// This file is the entry point and contains the datasource and generator configuration
// All models are organized in separate files by context in the same directory

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["academic-structure", "admissions", "ai", "audit-logging", "communication", "events", "finance", "health", "hr", "jwt-secrets", "learning", "library", "profile", "roles-permissions", "security-policy", "student-management", "tenant", "transportation", "user-management"]
}
