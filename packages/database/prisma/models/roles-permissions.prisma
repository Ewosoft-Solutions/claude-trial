// ============================================
// Roles and Permissions Models
// ============================================
//
// Schema Design Notes:
//
// 1. Roles:
//    - Platform roles (Architect, SuperAdmin) - tenantId = null
//    - System roles (Owner, Management, Teacher, etc.) - tenantId = null (global)
//    - Custom roles - tenantId = UUID (school-specific)
//    - Each role has clearance level (0-10) and role type
//
// 2. Permissions:
//    - 300+ granular permissions (resource.action format)
//    - Context-aware permissions (e.g., 'students.edit.own_classes')
//    - Permissions assigned to roles, can be overridden per profile
//
// See: _requirements/access-control.md for role hierarchy and clearance levels
// See: _requirements/permissions.md for complete permission list
// See: _actions/role-permissions-management.md for permission pool inheritance and custom role constraints
// ============================================

// Roles - System roles (platform) and custom roles (school-specific)
// 
// Role Types:
// - 'platform': Platform-level roles (Architect, SuperAdmin) - tenantId = null, name globally unique
// - 'system': System-level roles (Owner, Management, Teacher, etc.) - tenantId = null, name globally unique
// - 'custom': School-specific custom roles - tenantId = UUID, name unique per tenant
//
// Note: For platform/system roles (tenantId = null), ensure name is globally unique at application level.
// Prisma's @@unique([name, tenantId]) allows multiple NULL values, so application-level validation is needed.
model Role {
  id             String  @id @default(uuid())
  name           String // Globally unique for platform/system roles, tenant-specific for custom roles
  description    String?
  roleType       String  @map("role_type") // 'platform' | 'system' | 'custom'
  clearanceLevel Int     @map("clearance_level") // 0-10 (Architect=10, SuperAdmin=9, Owner=8, etc.)
  isSystemRole   Boolean @default(false) @map("is_system_role") // True for predefined roles
  tenantId       String? @map("tenant_id") // Null for platform/system roles, required for custom roles
  isActive       Boolean @default(true) @map("is_active")

  // Audit Fields
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userTenantRoles UserTenantRole[]
  rolePools       RolePermissionPool[]

  @@unique([name, tenantId]) // Name unique per tenant (for custom roles), application-level check needed for platform/system roles
  @@index([roleType])
  @@index([clearanceLevel])
  @@index([tenantId])
  @@index([isSystemRole])
  @@index([roleType, name]) // For platform/system role name uniqueness checks
  @@map("roles")
  @@schema("roles-permissions")
}

// Permissions - The 300+ granular permissions
// Structured metadata for UI rendering: key (name), label (display), description (details)
model Permission {
  id                     String  @id @default(uuid())
  name                   String  @unique // Key/identifier (e.g., 'students.view', 'grades.edit', 'platform.override')
  label                  String // Human-readable display name (e.g., 'View Students', 'Edit Grades')
  description            String? // Detailed description for UI rendering and tooltips
  resource               String // e.g., 'students', 'grades', 'platform'
  action                 String // e.g., 'view', 'edit', 'create', 'delete'
  context                String? // e.g., 'own_classes', 'children', 'department'
  category               String // e.g., 'academic', 'administrative', 'platform', 'financial'
  requiredClearanceLevel Int     @default(0) @map("required_clearance_level") // Minimum clearance level required

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  userTenantPermissions UserTenantPermission[]
  poolPermissions       PermissionPoolPermission[]

  @@index([resource])
  @@index([action])
  @@index([category])
  @@index([requiredClearanceLevel])
  @@index([resource, action]) // For fast permission lookups
  @@map("permissions")
  @@schema("roles-permissions")
}

// Permission Pools - Predefined sets of permissions grouped by clearance level
// Custom roles can only inherit permissions from pools matching their clearance level or below
model PermissionPool {
  id             String  @id @default(uuid())
  name           String // e.g., "Level10_PlatformArchitect", "Level7_SchoolManagement"
  clearanceLevel Int     @map("clearance_level") // 0-10
  description    String?
  isSystemPool   Boolean @default(true) @map("is_system_pool") // True for predefined pools
  tenantId       String? @map("tenant_id") // Null for system pools, can be set for tenant-specific pools

  // Audit Fields
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant?                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  poolPermissions PermissionPoolPermission[]
  rolePools       RolePermissionPool[]

  @@unique([name, tenantId]) // Name unique per tenant (for custom pools)
  @@index([clearanceLevel])
  @@index([isSystemPool])
  @@index([tenantId])
  @@map("permission_pools")
  @@schema("roles-permissions")
}

// Permission Pool Permissions - Many-to-many: Permission pools contain permissions
model PermissionPoolPermission {
  id           String   @id @default(uuid())
  poolId       String   @map("pool_id")
  permissionId String   @map("permission_id")
  addedAt      DateTime @default(now()) @map("added_at")
  addedBy      String?  @map("added_by")

  pool       PermissionPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  permission Permission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([poolId, permissionId])
  @@index([poolId])
  @@index([permissionId])
  @@map("permission_pool_permissions")
  @@schema("roles-permissions")
}

// Role Permission Pools - Many-to-many: Roles inherit from permission pools
model RolePermissionPool {
  id         String   @id @default(uuid())
  roleId     String   @map("role_id")
  poolId     String   @map("pool_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by")

  role Role           @relation(fields: [roleId], references: [id], onDelete: Cascade)
  pool PermissionPool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([roleId, poolId])
  @@index([roleId])
  @@index([poolId])
  @@map("role_permission_pools")
  @@schema("roles-permissions")
}

// Maker-Checker Requests - Persistent approvals for sensitive operations
model MakerCheckerRequest {
  id                    String    @id @default(uuid())
  tenantId              String?   @map("tenant_id")
  operation             String
  level                 String    @map("level") // ApprovalLevel
  status                String    @map("status") // ApprovalStatus
  makerId               String    @map("maker_id")
  makerClearanceLevel   Int       @map("maker_clearance_level")
  checkerId             String?   @map("checker_id")
  checkerClearanceLevel Int?      @map("checker_clearance_level")
  requestData           Json      @map("request_data")
  approvalReason        String?   @map("approval_reason")
  rejectionReason       String?   @map("rejection_reason")
  expiresAt             DateTime? @map("expires_at")
  approvedAt            DateTime? @map("approved_at")
  rejectedAt            DateTime? @map("rejected_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([operation])
  @@index([status])
  @@map("maker_checker_requests")
  @@schema("roles-permissions")
}
