# ============================================================
# packages/database — environment template
# ============================================================
# Copy to `packages/database/.env`. Used by Prisma CLI (migrate/seed/generate)
# and the RLS scripts. Always the OWNER connection — migrations and seed run as
# the owner, never as app_runtime. `.env` is gitignored.

NODE_ENV=development

# Owner DB connection (DDL-capable). Must match apps/api DATABASE_URL's host/db.
DATABASE_URL="postgresql://<user>:<password>@localhost:5432/schoolsys"

# Note: the restricted app_runtime connection (APP_RUNTIME_DATABASE_URL) lives
# in apps/api/.env, not here — Prisma tooling only needs the owner. The
# `db:rls:proof` script reads APP_RUNTIME_DATABASE_URL from the environment when
# proving isolation as app_runtime (see docs/database-setup.md §6).

# Platform Architect bootstrap (clearance level 10 — unrestricted access).
# Required by `db:seed` in EVERY environment; there is no built-in default, so
# the seed refuses to run without these. Generate a fresh password per
# environment and keep it in the secret store, never here:
#
#   SEED_ARCHITECT_PASSWORD=$(openssl rand -base64 24)
#
# The seeded account is created with forced rotation armed, so this password is
# single-use: it must be changed at first login via POST /auth/change-password.
SEED_ARCHITECT_EMAIL="architect@<your-domain>"
SEED_ARCHITECT_PASSWORD="<generate-me-min-16-chars>"
