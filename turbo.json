{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "PORT",
    "NEXT_PUBLIC_API_URL",
    "API_DEBUG_ERRORS",
    "VOYAGE_API_KEY",
    "AI_EMBEDDINGS_MODEL",
    "AI_EMBEDDINGS_DIMENSIONS",
    "AI_MONTHLY_TOKEN_BUDGET",
    "AI_TENANT_CONCURRENCY_LIMIT",
    "AI_SPEND_ALERT_THRESHOLD_PERCENT",
    "STORAGE_LOCAL_ROOT",
    "WEBAUTHN_RP_NAME",
    "WEBAUTHN_RP_ID",
    "WEBAUTHN_ORIGIN",
    "WEBAUTHN_ALLOWED_ORIGINS",
    "AUTH_RESUME_SECRET",
    "AUTH_IDLE_TIMEOUT_MIN_MINUTES",
    "AUTH_IDLE_TIMEOUT_MAX_MINUTES",
    "AUTH_IDLE_TIMEOUT_DEFAULT_MINUTES",
    "AUTH_IDLE_STANDARD_GRACE_SECONDS",
    "AUTH_IDLE_FOCUS_GRACE_SECONDS"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": ["IS_SERVERLESS"],
      "passThroughEnv": ["DATABASE_URL"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:deploy": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:seed": {
      "cache": false,
      "env": ["SEED_ARCHITECT_EMAIL"]
    },
    "db:generate": {
      "dependsOn": ["^db:generate"],
      "cache": false
    },
    "db:studio": {
      "cache": false
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/vitest.config.ts"],
      "dependsOn": ["transit", "@workspace/vitest-config#build"],
      "outputs": ["coverage.json"],
      "env": ["IS_SERVERLESS"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "bootstrap:architect-token": {
      "cache": false,
      "env": ["SEED_ARCHITECT_EMAIL"]
    }
  }
}
