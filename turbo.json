{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "PORT",
    "WEBAUTHN_RP_NAME",
    "WEBAUTHN_RP_ID",
    "WEBAUTHN_ORIGIN"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "env": ["IS_SERVERLESS"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:deploy": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "db:generate": {
      "dependsOn": ["^db:generate"],
      "cache": false
    },
    "db:studio": {
      "cache": false
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/vitest.config.ts"],
      "dependsOn": ["transit", "@workspace/vitest-config#build"],
      "outputs": ["coverage.json"],
      "env": ["IS_SERVERLESS"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    }
  }
}
