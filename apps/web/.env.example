# ============================================================
# apps/web — environment template
# ============================================================
# Copy to `apps/web/.env.local` and fill in. `.env.local` is gitignored.
# Only NEXT_PUBLIC_* vars are exposed to the browser bundle.

# Base URL of the NestJS API the web app talks to (server + client).
NEXT_PUBLIC_API_URL=http://localhost:3030

# Canonical public web origin. In production set this to the root application
# URL; middleware redirects only its `www` alias here and leaves service hosts
# such as `api.schoolwithease.com` untouched.
APP_CANONICAL_ORIGIN=https://schoolwithease.com

# HMAC key for short-lived, HTTP-only post-login resume state. Use a long,
# random value in deployed environments; do not expose it as NEXT_PUBLIC_*.
AUTH_RESUME_SECRET=

# Development-only floating utility for previewing CSS color variables.
NEXT_PUBLIC_SHOW_COLOR_SCHEME_PREVIEW=false

# Optional development-only host hint. Production tenancy is resolved from the
# authenticated school/profile context on the canonical application origin;
# school-specific production subdomains are not used.
# NEXT_PUBLIC_ROOT_DOMAIN=
