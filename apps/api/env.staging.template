# ============================================
# School With Ease - Staging Environment
# ============================================
# Copy this file to .env.staging and update with your actual values

DATABASE_URL=postgresql://user:password@staging-dbService.example.com:5432/schoolsys?sslmode=require
NODE_ENV=staging
PORT=3000

# Security - MUST be different from dev/prod
# IMPORTANT: Quote values if they contain '=' (base64 padding)
JWT_SECRET="staging-jwt-secret-change-this"
ENCRYPTION_KEY="staging-encryption-key-change-this"

# WebAuthn
WEBAUTHN_RP_NAME=School With Ease (Staging)
WEBAUTHN_RP_ID=staging.example.com
WEBAUTHN_ORIGIN=https://staging.example.com

# Database Pool
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT=10000
DB_QUERY_TIMEOUT=60000

# Database Logging
DB_LOG_QUERIES=false
DB_LOG_ERRORS=true
DB_LOG_WARNINGS=true

# MFA SMS - Use actual provider in staging
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# MFA Email - Use actual provider in staging
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_SECURE=true
SMTP_FROM_EMAIL=noreply@staging.example.com
SMTP_FROM_NAME=School With Ease

# Audit Logging
AUDIT_LOG_DESTINATION=all
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE_PATH=/var/log/schoolsys/audit.log

# Monitoring
MONITORING_PROVIDER=sentry
MONITORING_ENABLED=true
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=staging
ALERT_EMAIL=alerts@example.com
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
