# ============================================
# School With Ease - Environment Configuration
# ============================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env files to version control

# ============================================
# Database Configuration (REQUIRED)
# ============================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/schoolsys

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# Security Configuration
# ============================================
# JWT Secret (fallback - school-specific secrets are auto-generated)
# Generate with: openssl rand -base64 32
# IMPORTANT: Quote the value if it contains '=' (padding) - e.g., JWT_SECRET="your-secret-with-padding="
JWT_SECRET="your-fallback-jwt-secret-change-in-production"

# Encryption Key (for sensitive data encryption)
# Generate with: openssl rand -base64 32
# IMPORTANT: Quote the value if it contains '=' (padding) - e.g., ENCRYPTION_KEY="your-key-with-padding="
ENCRYPTION_KEY="your-encryption-key-change-in-production"

# ============================================
# WebAuthn Configuration
# ============================================
WEBAUTHN_RP_NAME=School With Ease
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# ============================================
# Database Connection Pool (Optional)
# ============================================
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT=5000
DB_QUERY_TIMEOUT=30000

# ============================================
# Database Logging (Optional)
# ============================================
DB_LOG_QUERIES=false
DB_LOG_ERRORS=true
DB_LOG_WARNINGS=true

# ============================================
# MFA SMS Configuration
# ============================================
# Provider: 'twilio' | 'aws-sns' | 'console' (for development)
SMS_PROVIDER=console

# Twilio Configuration (if SMS_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# AWS SNS Configuration (if SMS_PROVIDER=aws-sns)
# AWS_SNS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ============================================
# MFA Email Configuration
# ============================================
# Provider: 'smtp' | 'sendgrid' | 'ses' | 'console' (for development)
EMAIL_PROVIDER=console

# SMTP Configuration (if EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# SMTP_SECURE=false
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_FROM_NAME=School With Ease

# SendGrid Configuration (if EMAIL_PROVIDER=sendgrid)
# SENDGRID_API_KEY=your-sendgrid-api-key

# AWS SES Configuration (if EMAIL_PROVIDER=ses)
# AWS_SES_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ============================================
# Audit Logging Configuration
# ============================================
# Destination: 'database' | 'file' | 'external' | 'all'
AUDIT_LOG_DESTINATION=database
AUDIT_LOG_ENABLED=true

# File-based audit logs (if AUDIT_LOG_DESTINATION includes 'file')
# AUDIT_LOG_FILE_PATH=./logs/audit.log

# External audit service (if AUDIT_LOG_DESTINATION includes 'external')
# AUDIT_LOG_EXTERNAL_URL=https://audit-service.example.com/api/logs
# AUDIT_LOG_EXTERNAL_API_KEY=your-external-audit-api-key

# ============================================
# Monitoring & Alerting Configuration
# ============================================
# Provider: 'datadog' | 'newrelic' | 'sentry' | 'none'
MONITORING_PROVIDER=none
MONITORING_ENABLED=true

# DataDog Configuration (if MONITORING_PROVIDER=datadog)
# DATADOG_API_KEY=your-datadog-api-key
# DATADOG_APP_KEY=your-datadog-app-key

# New Relic Configuration (if MONITORING_PROVIDER=newrelic)
# NEW_RELIC_LICENSE_KEY=your-new-relic-license-key

# Sentry Configuration (if MONITORING_PROVIDER=sentry)
# SENTRY_DSN=your-sentry-dsn
# SENTRY_ENVIRONMENT=development

# Alerting
# ALERT_EMAIL=alerts@example.com
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
