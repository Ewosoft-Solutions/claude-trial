# ============================================
# School With Ease - Production Environment
# ============================================
# Copy this file to .env.production and update with your actual values
# NEVER commit production .env files to version control

DATABASE_URL=postgresql://user:password@prod-dbService.example.com:5432/schoolsys?sslmode=require&connection_limit=20
# Restricted runtime role (non-superuser, non-BYPASSRLS) — enables Postgres RLS
# enforcement for tenant-data services at runtime (ADR-004). Strongly recommended
# in production. Migrations still use DATABASE_URL (the owner).
APP_RUNTIME_DATABASE_URL=postgresql://app_runtime:CHANGE_ME@prod-dbService.example.com:5432/schoolsys?sslmode=require&connection_limit=20
NODE_ENV=production
PORT=3000

# Security - MUST be strong and unique
# Generate with: openssl rand -base64 64
# IMPORTANT: Always quote base64 secrets (they contain '=' padding)
JWT_SECRET="production-jwt-secret-must-be-strong-and-unique"
ENCRYPTION_KEY="production-encryption-key-must-be-strong-and-unique"

# WebAuthn
WEBAUTHN_RP_NAME=School With Ease
# The multitenant app is served from one canonical root origin. The RP ID has
# no scheme; browser origins below are exact HTTPS origins.
WEBAUTHN_RP_ID=schoolwithease.com
WEBAUTHN_ORIGIN=https://schoolwithease.com
# Accept the canonical app and its `www` alias. Do not add API or integration
# service subdomains: passkey ceremonies run on the web page origin.
WEBAUTHN_ALLOWED_ORIGINS=https://schoolwithease.com,https://www.schoolwithease.com
# Public web app origin, for links in outbound email (no trailing slash).
APP_WEB_URL=https://schoolwithease.com

# Database Pool
DB_POOL_MIN=10
DB_POOL_MAX=50
DB_CONNECTION_TIMEOUT=10000
DB_QUERY_TIMEOUT=60000

# Database Logging
DB_LOG_QUERIES=false
DB_LOG_ERRORS=true
DB_LOG_WARNINGS=true

# MFA SMS - Production provider
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-production-twilio-account-sid
TWILIO_AUTH_TOKEN=your-production-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# MFA Email - Production provider
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your-production-sendgrid-api-key
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=School With Ease

# Audit Logging - Use all destinations for redundancy
AUDIT_LOG_DESTINATION=all
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE_PATH=/var/log/schoolsys/audit.log
AUDIT_LOG_EXTERNAL_URL=https://audit-service.example.com/api/logs
AUDIT_LOG_EXTERNAL_API_KEY=your-external-audit-api-key

# Monitoring - Comprehensive monitoring
MONITORING_PROVIDER=datadog
MONITORING_ENABLED=true
DATADOG_API_KEY=your-production-datadog-api-key
DATADOG_APP_KEY=your-production-datadog-app-key
ALERT_EMAIL=alerts@example.com
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
