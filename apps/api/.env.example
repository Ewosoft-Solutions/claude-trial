# ============================================================
# apps/api — environment template
# ============================================================
# Copy to `apps/api/.env` and fill in. `.env` is gitignored; never commit
# real secrets. Validation + defaults live in
# apps/api/src/common/config/env.config.ts. Full setup: docs/database-setup.md.

# ---- Core ---------------------------------------------------------------
NODE_ENV=development
PORT=3030

# Owner DB connection — used by migrations, seed, and platform/cross-tenant
# reads. postgres(ql):// only.
DATABASE_URL="postgresql://<user>:<password>@localhost:5432/schoolsys"

# ---- RLS runtime enforcement (ADR-004) — docs/database-setup.md §5–6 -----
# Restricted, non-BYPASSRLS `app_runtime` connection for tenant-scoped queries
# so Postgres RLS enforces isolation at runtime. Same host/db as DATABASE_URL,
# with the `app_runtime` user + password (ALTER ROLE app_runtime PASSWORD …).
# Unset → tenant queries use the owner connection (RLS bypassed; boot warns).
# APP_RUNTIME_DATABASE_URL="postgresql://app_runtime:<secret>@localhost:5432/schoolsys"

# Force the boot-time RLS self-test to fail-closed instead of warn. Defaults to
# ON in production, OFF elsewhere. true → enforce; false → opt out deliberately.
# DB_RLS_ENFORCED=false

# ---- Secrets (required outside local) -----------------------------------
# AES-256-GCM key for encrypted columns (JWT/MFA secrets, BYOK AI keys).
# Prefer a base64-encoded 32-byte value. A dev default is used if unset — NEVER
# rely on that in production.
ENCRYPTION_KEY=
# JWT signing secret (per-tenant JWT config may override at runtime).
JWT_SECRET=

# ---- WebAuthn / passkeys ------------------------------------------------
WEBAUTHN_RP_NAME="School With Ease"
# RP ID must be the apex registrable domain so one passkey works across all
# tenant subdomains of it.
WEBAUTHN_RP_ID=localhost
# The origin the WEB APP is served from (where the passkey ceremony runs) — the
# dev web app runs on :3001, NOT the API port.
WEBAUTHN_ORIGIN=http://localhost:3001
# Comma-separated allow-list of assertion origins (e.g. tenant subdomains).
# Optional — defaults to WEBAUTHN_ORIGIN when unset.
# WEBAUTHN_ALLOWED_ORIGINS=http://localhost:3001

# ---- Storage ------------------------------------------------------------
# Root dir for local-disk lesson material binaries (relative to the API cwd).
STORAGE_LOCAL_ROOT=./storage

# ---- AI (optional; features degrade gracefully when unset) --------------
AI_ENABLED=true
# Anthropic key is spend-capped — mind the cap. Voyage key is free-tier.
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
AI_MODEL=claude-opus-4-8
AI_MODEL_ANALYTICS=claude-opus-4-8
AI_EMBEDDINGS_MODEL=voyage-3
AI_EMBEDDINGS_DIMENSIONS=1024
AI_MAX_TOKENS=4096
AI_TOOL_LOOP_MAX_ITERATIONS=5
AI_HISTORY_MAX_MESSAGES=20
AI_RATE_LIMIT_PER_MINUTE=10
AI_DAILY_MESSAGE_CAP=200
AI_MONTHLY_TOKEN_BUDGET=1000000
AI_TENANT_CONCURRENCY_LIMIT=3
AI_SPEND_ALERT_THRESHOLD_PERCENT=80

# ---- DB pool / logging (optional; sensible defaults) --------------------
# DB_POOL_MIN=2
# DB_POOL_MAX=10
# DB_CONNECTION_TIMEOUT=5000
# DB_QUERY_TIMEOUT=15000
# DB_LOG_QUERIES=false
# DB_LOG_ERRORS=true
# DB_LOG_WARNINGS=true

# ---- Diagnostics (optional) ---------------------------------------------
# Expose error details/stack on HTTP responses. Defaults false; must be set
# explicitly — NODE_ENV=development alone never exposes internals.
# API_DEBUG_ERRORS=false

# ---- Optional integrations (leave blank to disable) ---------------------
# Email: EMAIL_PROVIDER=smtp|sendgrid|ses  + the matching block below
# SMTP_HOST= / SMTP_PORT= / SMTP_USER= / SMTP_PASSWORD= / SMTP_SECURE=false
# SMTP_FROM_EMAIL= / SMTP_FROM_NAME=
# SENDGRID_API_KEY=   AWS_SES_REGION=
# SMS: SMS_PROVIDER=twilio|sns
# TWILIO_ACCOUNT_SID= / TWILIO_AUTH_TOKEN= / TWILIO_PHONE_NUMBER=
# AWS_SNS_REGION= / AWS_ACCESS_KEY_ID= / AWS_SECRET_ACCESS_KEY=
# Audit log sink: AUDIT_LOG_ENABLED=true AUDIT_LOG_DESTINATION=file|external
# AUDIT_LOG_FILE_PATH= / AUDIT_LOG_EXTERNAL_URL= / AUDIT_LOG_EXTERNAL_API_KEY=
# Monitoring: MONITORING_ENABLED=true MONITORING_PROVIDER=datadog|newrelic|sentry
# DATADOG_API_KEY= / DATADOG_APP_KEY= / NEW_RELIC_LICENSE_KEY=
# SENTRY_DSN= / SENTRY_ENVIRONMENT=
# Alerting: ALERT_EMAIL= / ALERT_WEBHOOK_URL=
